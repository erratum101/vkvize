{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npm run build -w @vkvize/shared && npm run build -w @vkvize/server"
  },
  "deploy": {
    "startCommand": "npm run start -w @vkvize/server",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30
  }
}
