# Supabase (server)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=quiz-images

# Supabase PostgreSQL (Settings → Database → Connection string)
# DATABASE_URL — Transaction pooler (port 6543) for runtime
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL — Session mode (port 5432) for migrations
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

PORT=4000
CORS_ORIGIN=https://vkvize-server.vercel.app
